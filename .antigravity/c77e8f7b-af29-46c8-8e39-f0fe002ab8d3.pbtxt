        }
        lines {
          text: "    const activeStep = currentStep;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (stepCallback) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      // Run callback on animation frame or defer to avoid state locking"
