        }
        lines {
          text: "  getAnalyser: () => {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    initAudio();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    return analyserNode;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
