    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { SERVICES } from \"../data\";\nimport { Sliders, Disc, Activity, CheckCircle2, Award } from \"lucide-react\";\nimport { motion } from \"motion/react\";\n\nconst iconMap = {\n  Sliders: Sliders,\n  Disc: Disc,\n  Activity: Activity,\n};\n\nexport default function Services() {\n  return (\n    <section id=\"servicios\" className=\"relative py-28 px-4 bg-gradient-to-b from-black to-[#050508] scroll-mt-12\">\n      <div className=\"absolute inset-0 grid-mesh opacity-20 pointer-events-none\" />\n      \n      {/* Background ambient lights */}\n      <div className=\"absolute top-1/2 right-10 w-96 h-96 bg-cyber-green/5 rounded-full blur-[140px] pointer-events-none\" />\n      <div className=\"absolute bottom-10 left-12 w-96 h-96 bg-cyber-violet/5 rounded-full blur-[140px] pointer-events-none\" />\n\n      <div className=\"max-w-6xl mx-auto z-10 relative\">\n        {/* Header Title */}\n        <div className=\"text-center mb-20\">\n          <span className=\"text-xs font-mono tracking-widest text-cyber-violet\">\n            [ ESTUDIO DE GRABACI\303\223N & SERVICIOS H\303\215BRIDOS ]\n          </span>\n          <h2 className=\"text-3xl md:text-5xl font-display font-medium text-white tracking-tight mt-2\">\n            SERVICIOS DE PRODUCCI\303\223N DISCOGR\303\201FICA\n          </h2>\n          <p className=\"text-gray-400 text-sm md:text-base mt-4 max-w-xl mx-auto font-light leading-relaxed\">\n            Consigue el peso, la anchura tridimensional y la fidelidad psicoac\303\272stica que diferencia a los artistas independientes de los l\303\255deres mundiales.\n          </p>\n        </div>\n\n        {/* Gear Rack Services Columns */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch font-sans\">\n          {SERVICES.map((service, index) => {\n            const IconComponent = iconMap[service.icon as keyof typeof iconMap] || Activity;\n            const isViolet = service.glowColor === \"violet\";\n            const isGreen = service.glowColor === \"green\";\n            const isCyan = service.glowColor === \"cyan\";\n\n            // Define borders & text glow colors\n            const glowBorderClass = isViolet\n              ? \"hover:border-cyber-violet/40 hover:shadow-cyber-violet/10 focus-within:border-cyber-violet/40\"\n              : isGreen\n              ? \"hover:border-cyber-green/40 hover:shadow-cyber-green/10\"\n              : \"hover:border-cyber-cyan/40 hover:shadow-cyber-cyan/10\";\n            \n            const accentTextClass = isViolet\n              ? \"text-cyber-violet\"\n              : isGreen\n              ? \"text-cyber-green\"\n              : \"text-cyber-cyan\";\n\n            const accentBgClass = isViolet\n              ? \"bg-cyber-violet/10 text-cyber-violet\"\n              : isGreen\n              ? \"bg-cyber-green/10 text-cyber-green\"\n              : \"bg-cyber-cyan/10 text-cyber-cyan\";\n\n            return (\n              <motion.div\n                key={service.id}\n                initial={{ opacity: 0, y: 30 }}\n                whileInView={{ opacity: 1, y: 0 }}\n                viewport={{ once: true, margin: \"-100px\" }}\n                transition={{ duration: 0.6, delay: index * 0.15 }}\n                className={`glass-panel p-8 rounded-3xl border border-white/5 relative flex flex-col justify-between transition-all duration-500 group overflow-hidden ${glowBorderClass}`}\n              >\n                {/* Horizontal glowing top accent on hover */}\n                <div\n                  className={`absolute top-0 left-0 right-0 h-[2px] scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left ${\n                    isViolet ? \"bg-cyber-violet\" : isGreen ? \"bg-cyber-green\" : \"bg-cyber-cyan\"\n                  }`}\n                />\n\n                <div>\n                  {/* Top Header Badge */}\n                  <div className=\"flex justify-between items-start mb-6\">\n                    <div className={`p-3.5 rounded-2xl ${accentBgClass}`}>\n                      <IconComponent className=\"w-6 h-6\" />\n                    </div>\n                    \n                    {service.badge && (\n                      <span className=\"text-[9px] font-mono tracking-widest uppercase bg-white/5 px-2.5 py-1 rounded-full border border-white/10 text-white flex items-center gap-1.5 font-light\">\n                        <Award className=\"w-3 h-3 text-yellow-500\" />\n                        {service.badge}\n                      </span>\n                    )}\n                  </div>\n\n                  {/* Pricing/Header Categories */}\n                  <span className=\"text-[10px] font-mono tracking-widest text-gray-500 uppercase\">\n                    {service.category}\n                  </span>\n                  \n                  <h3 className=\"text-2xl font-display font-medium text-white tracking-tight mt-1 mb-4 group-hover:text-white/90 transition-colors\">\n                    {service.title}\n                  </h3>\n\n                  <p className=\"text-sm text-gray-400 font-light leading-relaxed mb-6\">\n                    {service.description}\n                  </p>\n\n                  {/* Render simulated high-fidelity technical rack specifications */}\n                  <div className=\"mb-6 rounded-xl bg-black/40 border border-white/5 p-4 font-mono text-[10px] text-gray-500 space-y-1\">\n                    <p className=\"flex justify-between\">\n                      <span>RACK INTERFACE:</span>\n                      <span className=\"text-white\">SSL SUMMING AMP</span>\n                    </p>\n                    <p className=\"flex justify-between\">\n                      <span>SAMPLE DEPTH:</span>\n                      <span className=\"text-white\">192KHZ 32-BIT FLOAT</span>\n                    </p>\n                    <p className=\"flex justify-between\">\n                      <span>ANALOG HARDWARE:</span>\n                      <span className=\"text-white\">CLASS-A ACTIVE</span>\n                    </p>\n                    <p className=\"flex justify-between\">\n                      <span>COMPATIBILIDAD:</span>\n                      <span className=\"text-white\">ATMOS / RED BOOK</span>\n                    </p>\n                  </div>\n\n                  {/* Features Checklist */}\n                  <div className=\"border-t border-white/5 pt-6 mb-8\">\n                    <p className=\"text-xs font-mono text-gray-500 uppercase tracking-widest mb-4\">\n                      Especificaciones de Entrega\n                    </p>\n                    \n                    <ul className=\"space-y-3\">\n                      {service.features.map((feature, idx) => (\n                        <li key={idx} className=\"flex items-start gap-3 text-xs md:text-sm text-gray-300 font-light\">\n                          <CheckCircle2 className={`w-4 h-4 shrink-0 mt-0.5 ${accentTextClass}`} />\n                          <span>{feature}</span>\n                        </li>\n                      ))}\n                    </ul>\n                  </div>\n                </div>\n\n                {/* Card CTA Footer */}\n                <div className=\"border-t border-white/5 pt-6 flex justify-between items-center mt-auto font-mono text-xs\">\n                  <div>\n                    <p className=\"text-gray-500 text-[9px] uppercase\">Tiempo estimado</p>\n                    <p className=\"text-white font-medium mt-0.5\">{service.duration}</p>\n                  </div>\n                  \n                  <span\n                    className={`px-4 py-2 rounded-lg border border-white/5 bg-white/[0.02] cursor-pointer group-hover:border-white/15 hover:bg-white/[0.05] transition-all duration-300 ${accentTextClass}`}\n                  >\n                    Ver Detalles\n                  </span>\n                </div>\n              </motion.div>\n            );\n          })}\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    }
