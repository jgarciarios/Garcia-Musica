        }
        lines {
          text: "    const now = audioCtx.currentTime;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode.frequency.setTargetAtTime(cutoff, now, 0.03); // smooth ramp"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
