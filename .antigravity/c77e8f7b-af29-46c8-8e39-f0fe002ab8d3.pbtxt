    replacement_chunks {
      replacement_content: "import { StemTrack, ServiceItem, Testimonial } from \"./types\";\n\nexport const TRACKS: StemTrack[] = [\n  {\n    id: \"neo-tokyo-drive\",\n    title: \"Neo-Tokyo Drive\",\n    genre: \"Cyberpunk / Industrial Electro\",\n    bpm: 125,\n    key: \"F# Minor\",\n    duration: \"1:42\",\n    color: \"cyan\",\n    description: \"Sintetizadores corrosivos, bajos cyberpunk distorsionados y percusi\303\263n industrial agresiva de ritmo implacable.\",\n    baseFreq: 185.0, // F#3\n    synthTempo: 125,\n    tracks: {\n      drums: true,\n      bass: true,\n      lead: true,\n      space: true,\n    }\n  },\n  {\n    id: \"solaris-reflection\",\n    title: \"Solaris Reflection\",\n    genre: \"Cinematic Ambient / Downtempo\",\n    bpm: 90,\n    key: \"C Major\",\n    duration: \"2:15\",\n    color: \"violet\",\n    description: \"Texturas anal\303\263gicas profundas, acordes espaciales flotantes y micro-pulsos de ritmo meditativo envolvente.\",\n    baseFreq: 130.8, // C3\n    synthTempo: 90,\n    tracks: {\n      drums: true,\n      bass: true,\n      lead: true,\n      space: true,\n    }\n  },\n  {\n    id: \"sunset-grid\",\n    title: \"Sunset Grid\",\n    genre: \"Retro Synthwave / Outrun\",\n    bpm: 115,\n    key: \"A Minor\",\n    duration: \"1:55\",\n    color: \"green\",\n    description: \"L\303\255neas de bajo arpegiadas ultra-nost\303\241lgicas, percusi\303\263n vintage de compuertas anal\303\263gicas y leads retro-futuristas.\",\n    baseFreq: 110.0, // A2\n    synthTempo: 115,\n    tracks: {\n      drums: true,\n      bass: true,\n      lead: true,\n      space: true,\n    }\n  }\n];\n\nexport const SERVICES: ServiceItem[] = [\n  {\n    id: \"mixing-analog\",\n    title: \"Mezcla H\303\255brida Est\303\251reo\",\n    category: \"Mixing & Post-Production\",\n    description: \"Alcanza claridad tridimensional, pegada masiva y pegamento s\303\263nico. Mezclamos tus stems combinando hardware anal\303\263gico real clase A (SSL Bus Compressor, EQ Neve) y lo \303\272ltimo en plugins DSP de nivel cient\303\255fico.\",\n    icon: \"Sliders\",\n    features: [\n      \"Saturaci\303\263n de cinta anal\303\263gica Real\",\n      \"Control de fase, transitorios y din\303\241micas\",\n      \"Afinaci\303\263n y alineaci\303\263n de voces integrada\",\n      \"Formatos exportados listos para Masterizaci\303\263n\"\n    ],\n    duration: \"3-5 d\303\255as laborables\",\n    glowColor: \"cyan\",\n    badge: \"Est\303\241ndar de la Industria\"\n  },\n  {\n    id: \"full-production\",\n    title: \"Producci\303\263n Ejecutiva de Cero\",\n    category: \"Executive Production\",\n    description: \"Transforma tu maqueta inicial en un himno estelar listo para reproducirse en festivales y Spotify global. Dise\303\261amos la instrumentaci\303\263n, el ritmo, los arpegios, y pulimos la direcci\303\263n est\303\251tica completa de tu canci\303\263n.\",\n    icon: \"Disc\",\n    features: [\n      \"Arreglos completos de sintetizadores y ritmos\",\n      \"Co-composici\303\263n y estructuraci\303\263n radio-ready\",\n      \"Grabaci\303\263n y post-producci\303\263n avanzada\",\n      \"Hasta 4 Rondas de refinamiento quir\303\272rgico\"\n    ],\n    duration: \"2-4 semanas\",\n    glowColor: \"violet\",\n    badge: \"M\303\241s Solicitado\"\n  },\n  {\n    id: \"high-end-mastering\",\n    title: \"Masterizaci\303\263n de Presi\303\263n\",\n    category: \"Mastering Engine\",\n    description: \"El paso final indispensable para el impacto s\303\263nico absoluto. Asegura niveles competitivos de volumen percibido (LUFS), balance frecuencial perfecto y fidelidad extrema para reproducirse en sistemas line array y auriculares premium.\",\n    icon: \"Activity\",\n    features: [\n      \"Maximizaci\303\263n lim\303\255trofe psicoac\303\272stica\",\n      \"Tratamiento M/S (Mid-Side) especializado\",\n      \"Exportaci\303\263n de archivos de audio de alta resoluci\303\263n\",\n      \"Archivos Dolby Atmos & optimizaci\303\263n de streaming\"\n    ],\n    duration: \"24-48 horas\",\n    glowColor: \"green\"\n  }\n];\n\nexport const TESTIMONIALS: Testimonial[] = [\n  {\n    id: \"valerya\",\n    name: \"Valerya\",\n    role: \"Productora Techno & DJ\",\n    avatar: \"https://images.unsplash.com/photo-1534528741775-53994a69daeb?auto=format&fit=crop&w=150&q=80\",\n    quote: \"La precisi\303\263n en el rango de sub-bajos de Garc\303\255a transform\303\263 mis tracks de club. \'Neutron\' suena brutalmente ancho en sistemas Funktion-One y conserva un balance impresionante en plataformas digitales.\",\n    project: \"\303\201lbum \'S\303\263lido\' \342\200\224 Mezcla & M\303\241ster\",\n    rating: 5,\n    glowColor: \"cyan\"\n  },\n  {\n    id: \"marcus-thorne\",\n    name: \"Marcus Thorne\",\n    role: \"Compositor Core de Sci-Fi Audio\",\n    avatar: \"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=150&q=80\",\n    quote: \"Buscaba amalgamar sintetizadores anal\303\263gicos rudos junto a secuencias modulares vivas. Lo que Garc\303\255a aport\303\263 a nivel de dise\303\261o de sonido super\303\263 toda expectativa creativa. Es un genio s\303\263nico.\",\n    project: \"OST \'Cyber-Grid 3\' \342\200\224 Dise\303\261o de Sonido\",\n    rating: 5,\n    glowColor: \"violet\"\n  },\n  {\n    id: \"kaelen\",\n    name: \"Kaelen\",\n    role: \"Lanzadora Pop Industrial / Vocalista\",\n    avatar: \"https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=150&q=80\",\n    quote: \"Tengo un estilo muy vocal, y me aterrorizaba que los synths apagaran mi voz. Garc\303\255a cre\303\263 un espacio tridimensional perfecto donde cada consonante susurrada corta la mezcla con una calidez m\303\241gica.\",\n    project: \"EP \'Vapor Dream\' \342\200\224 Producci\303\263n Integral\",\n    rating: 5,\n    glowColor: \"green\"\n  }\n];\n"
    }
