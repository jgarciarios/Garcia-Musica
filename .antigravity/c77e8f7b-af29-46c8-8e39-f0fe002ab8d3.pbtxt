        lines {
          text: "// Allows user to control stems, BPM, and XY filters with high performance"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let audioCtx: AudioContext | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let isPlaying = false;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let currentBpm = 120;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let baseFrequency = 110.0; // Base note frequency"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let activeTrackId = \"\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Web Audio Nodes"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let masterGain: GainNode | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let delayNode: DelayNode | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let filterNode: BiquadFilterNode | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let analyserNode: AnalyserNode | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Sequencer state"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let currentStep = 0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let nextNoteTime = 0.0;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "const scheduleAheadTime = 0.1; // How far ahead to schedule audio (sec)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "const lookahead = 25.0; // How frequently to call scheduling function (ms)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let timerId: any = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// active stems state (managed inside or from UI)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let stemsState = {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  drums: true,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bass: true,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  lead: true,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  space: true,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "};"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Callback to notify UI of current playing step"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "let stepCallback: ((step: number) => void) | null = null;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Initialize or resume the audio context"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function initAudio() {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!audioCtx) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    audioCtx = new AudioContextClass();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Create master nodes"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    analyserNode = audioCtx.createAnalyser();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    analyserNode.fftSize = 256;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    masterGain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    masterGain.gain.setValueAtTime(0.4, audioCtx.currentTime); // Safe volume"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode = audioCtx.createBiquadFilter();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode.type = \"lowpass\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode.frequency.setValueAtTime(2000, audioCtx.currentTime);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode.Q.setValueAtTime(4.0, audioCtx.currentTime); // Resonance"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    delayNode = audioCtx.createDelay(1.0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    delayNode.delayTime.setValueAtTime(0.33, audioCtx.currentTime); // Dotted eighth delay"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    const delayGain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    delayGain.gain.setValueAtTime(0.35, audioCtx.currentTime); // Feedback level"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Wire up: Synth Notes -> Filter -> MasterGain & Delay"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Delay -> DelayGain -> back to Delay & MasterGain"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    delayNode.connect(delayGain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    delayGain.connect(delayNode); // Feedback loop"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    delayGain.connect(analyserNode); // Feed delay to analyser too"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode.connect(masterGain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    filterNode.connect(delayNode); // Send to delay"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    masterGain.connect(analyserNode);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    analyserNode.connect(audioCtx.destination);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (audioCtx.state === \"suspended\") {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    audioCtx.resume();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Low-level voice generation"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function playKick(time: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!audioCtx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const osc = audioCtx.createOscillator();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const gain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.connect(gain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.connect(masterGain!); // bypass filter to keep kick deep & punchy"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Frequency sweep: 150Hz -> 0.01Hz (standard punchy kick trick)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.frequency.setValueAtTime(150, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.frequency.exponentialRampToValueAtTime(0.01, time + 0.18);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Volume decay"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.setValueAtTime(0.9, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.exponentialRampToValueAtTime(0.01, time + 0.18);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.stop(time + 0.19);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function playHiHat(time: number, accent: boolean = false) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!audioCtx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Hi-hat synthesized via high-passed noise source"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const bufferSize = audioCtx.sampleRate * 0.05; // Short 50ms buffer"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const buffer = audioCtx.createBuffer(1, bufferSize, audioCtx.sampleRate);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const data = buffer.getChannelData(0);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  for (let i = 0; i < bufferSize; i++) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    data[i] = Math.random() * 2 - 1;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const noiseSource = audioCtx.createBufferSource();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  noiseSource.buffer = buffer;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const filter = audioCtx.createBiquadFilter();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  filter.type = \"highpass\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  filter.frequency.setValueAtTime(8000, time); // High frequency tick"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const gain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.setValueAtTime(accent ? 0.22 : 0.11, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.exponentialRampToValueAtTime(0.001, time + (accent ? 0.045 : 0.025));"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  noiseSource.connect(filter);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  filter.connect(gain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.connect(filterNode!); // feed to master filter"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  noiseSource.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  noiseSource.stop(time + 0.05);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function playBass(time: number, frequency: number, duration: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!audioCtx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const osc = audioCtx.createOscillator();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const subOsc = audioCtx.createOscillator();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const gain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const bassFilter = audioCtx.createBiquadFilter();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.type = \"sawtooth\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.frequency.setValueAtTime(frequency, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Thick sub layer"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  subOsc.type = \"sine\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  subOsc.frequency.setValueAtTime(frequency / 2, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bassFilter.type = \"lowpass\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bassFilter.frequency.setValueAtTime(320, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bassFilter.Q.setValueAtTime(1.0, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // ADSR envelope"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.setValueAtTime(0.01, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.linearRampToValueAtTime(0.35, time + 0.015); // Quick attack"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.exponentialRampToValueAtTime(0.01, time + duration - 0.01);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.connect(bassFilter);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  subOsc.connect(bassFilter);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  bassFilter.connect(gain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.connect(filterNode!);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  subOsc.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.stop(time + duration);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  subOsc.stop(time + duration);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function playLead(time: number, frequency: number, duration: number, isMajor: boolean = false) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!audioCtx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const osc1 = audioCtx.createOscillator();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const osc2 = audioCtx.createOscillator();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const gain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc1.type = \"triangle\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc1.frequency.setValueAtTime(frequency, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Detuned second oscillator for lush width"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc2.type = \"sawtooth\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc2.frequency.setValueAtTime(frequency * 1.008, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.setValueAtTime(0.01, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.linearRampToValueAtTime(0.24, time + 0.03); // Soft attack"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.exponentialRampToValueAtTime(0.01, time + duration - 0.01);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc1.connect(gain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc2.connect(gain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.connect(filterNode!);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc1.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc2.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc1.stop(time + duration);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc2.stop(time + duration);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function playSpacePluck(time: number, frequency: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (!audioCtx) return;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const osc = audioCtx.createOscillator();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const gain = audioCtx.createGain();"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.type = \"sawtooth\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Pitch octave shift (high pitch)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.frequency.setValueAtTime(frequency * 4, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.frequency.exponentialRampToValueAtTime(frequency * 2, time + 0.15);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.setValueAtTime(0.08, time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.gain.exponentialRampToValueAtTime(0.001, time + 0.25);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.connect(gain);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  gain.connect(delayNode!); // Directly feed deep space delay echo"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.start(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  osc.stop(time + 0.3);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// MIDI Scale notes offsets (pentatonic minor)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "const PENTATONIC_STEPS = [0, 3, 5, 7, 10, 12, 15, 17, 19, 22];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "const MAJOR_STEPS = [0, 2, 4, 7, 9, 12, 14, 16, 19, 21];"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function getFreqFromScale(baseFreq: number, stepIndex: number, scaleType: \"minor\" | \"major\") {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const scale = scaleType === \"minor\" ? PENTATONIC_STEPS : MAJOR_STEPS;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const index = Math.abs(stepIndex) % scale.length;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const octaveShift = Math.floor(stepIndex / scale.length);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const semitones = scale[index] + (octaveShift * 12);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // Frequency calculation f = f0 * 2^(n/12)"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  return baseFreq * Math.pow(2, semitones / 12);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "}"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "// Main sequencer note scheduler"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "function scheduleNote(step: number, time: number) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  const scaleType = activeTrackId === \"solaris-reflection\" ? \"major\" : \"minor\";"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  // 1. Drums Step Logic"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  if (stemsState.drums) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Four on the floor kick"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (step % 4 === 0) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      playKick(time);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    // Tech Snare / Clap accent"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (step % 8 === 4 && activeTrackId === \"neo-tokyo-drive\") {"
