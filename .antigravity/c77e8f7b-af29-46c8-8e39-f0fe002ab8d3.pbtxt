  file_change {
    absolute_path_uri: "file:///src/components/ContactForm.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { ArrowRight, CornerDownLeft, Sparkles, Send, RefreshCw, Cpu, Volume2, ShieldCheck } from \"lucide-react\";\n\nexport default function ContactForm() {\n  const [step, setStep] = useState(0);\n  const [formData, setFormData] = useState({\n    name: \"\",\n    service: \"\",\n    budget: \"\",\n    email: \"\",\n    comments: \"\",\n  });\n  const [errorMsg, setErrorMsg] = useState(\"\");\n  const [isCompiling, setIsCompiling] = useState(false);\n  const [compilingLogs, setCompilingLogs] = useState<string[]>([]);\n\n  const handleNextStep = () => {\n    setErrorMsg(\"\");\n    \n    if (step === 0 && !formData.name.trim()) {\n      setErrorMsg(\"Dinos tu nombre o alias para poder saludarte.\");\n      return;\n    }\n    \n    if (step === 1 && !formData.service) {\n      setErrorMsg(\"Por favor selecciona una categor\303\255a de servicio.\");\n      return;\n    }\n    \n    if (step === 2 && !formData.budget) {\n      setErrorMsg(\"Seleccione un rango de presupuesto estimado.\");\n      return;\n    }\n    \n    if (step === 3) {\n      if (!formData.email.trim() || !formData.email.includes(\"@\")) {\n        setErrorMsg(\"Ingresa una direcci\303\263n de correo v\303\241lida para enviarte la propuesta.\");\n        return;\n      }\n      \n      // Trigger compiler micro-animation\n      triggerSubmissionCompile();\n      return;\n    }\n    \n    setStep((prev) => prev + 1);\n  };\n\n  const handlePrevStep = () => {\n    setErrorMsg(\"\");\n    if (step > 0) {\n      setStep((prev) => prev - 1);\n    }\n  };\n\n  const selectService = (serviceName: string) => {\n    setFormData({ ...formData, service: serviceName });\n    setErrorMsg(\"\");\n    setTimeout(() => {\n      setStep(2);\n    }, 300);\n  };\n\n  const selectBudget = (budgetValue: string) => {\n    setFormData({ ...formData, budget: budgetValue });\n    setErrorMsg(\"\");\n    setTimeout(() => {\n      setStep(3);\n    }, 300);\n  };\n\n  const triggerSubmissionCompile = () => {\n    setIsCompiling(true);\n    setCompilingLogs([]);\n    \n    const logs = [\n      \"\342\232\241 CONECTANDO CON SERVIDOR DE SE\303\221AL DE GARC\303\215A M\303\232SICA...\",\n      \"\360\237\224\254 BUSCANDO CANAL DE TRANSMISI\303\223N DE DATOS SEGURO [ECC83-LINK]...\",\n      \"\342\232\231\357\270\217 ENGRANANDO PAR\303\201METROS: \" + formData.service.toUpperCase() + \"...\",\n      \"\360\237\223\235 INYECTANDO PROPUESTA FINANCIERA: \" + formData.budget.toUpperCase() + \"...\",\n      \"\360\237\224\222 COMPILANDO ALIAS DEL ARTISTA: \" + formData.name.toUpperCase() + \"...\",\n      \"\360\237\223\210 ENVIANDO CORREO DE RETROALIMENTACI\303\223N A: \" + formData.email.toLowerCase() + \"...\",\n      \"\360\237\222\216 PROCESO COMPLETADO EXCELENTEMENTE. MENSAJE EN COLA.\"\n    ];\n\n    logs.forEach((log, index) => {\n      setTimeout(() => {\n        setCompilingLogs((prev) => [...prev, log]);\n        if (index === logs.length - 1) {\n          setTimeout(() => {\n            setIsCompiling(false);\n            setStep(4); // Success step\n          }, 850);\n        }\n      }, (index + 1) * 450);\n    });\n  };\n\n  const resetForm = () => {\n    setFormData({\n      name: \"\",\n      service: \"\",\n      budget: \"\",\n      email: \"\",\n      comments: \"\",\n    });\n    setStep(0);\n    setErrorMsg(\"\");\n    setCompilingLogs([]);\n  };\n\n  return (\n    <section id=\"contacto\" className=\"relative py-28 px-4 bg-gradient-to-b from-[#050508] to-[#020202] scroll-mt-12\">\n      <div className=\"absolute inset-0 grid-mesh opacity-35 pointer-events-none\" />\n      \n      {/* Background glowing particles blur */}\n      <div className=\"absolute bottom-1/4 left-1/4 w-80 h-80 bg-cyber-violet/5 rounded-full blur-[120px] pointer-events-none\" />\n      <div className=\"absolute top-1/4 right-1/4 w-80 h-80 bg-cyber-cyan/5 rounded-full blur-[120px] pointer-events-none\" />\n\n      <div className=\"max-w-3xl mx-auto z-10 relative\">\n        {/* Section title */}\n        <div className=\"text-center mb-16\">\n          <span className=\"text-xs font-mono tracking-widest text-[#a78bfa]\">\n            [ AGENDAMIENTO DIRECTO & PROPUESTA ]\n          </span>\n          <h2 className=\"text-3xl md:text-5xl font-display font-medium text-white tracking-tight mt-2\">\n            INICIA TU PROYECTO S\303\223NICO\n          </h2>\n          <p className=\"text-gray-400 text-sm md:text-base mt-4 max-w-lg mx-auto font-light leading-relaxed\">\n            Sin formularios fr\303\255os. Dinos qui\303\251n eres y qu\303\251 buscas. Garc\303\255a responder\303\241 con un plan de acci\303\263n para llevar tu sonido a plataformas con un est\303\241ndar global.\n          </p>\n        </div>\n\n        {/* Console Box Container */}\n        <div className=\"glass-panel-heavy p-8 md:p-12 rounded-3xl border border-white/5 shadow-2xl relative min-h-[380px] flex flex-col justify-between overflow-hidden\">\n          \n          {/* Subtle Rack Ear designs to simulate high-end studio rack gear */}\n          <div className=\"absolute top-0 bottom-0 left-0 w-1 bg-white/5\" />\n          <div className=\"absolute top-0 bottom-0 right-0 w-1 bg-white/5\" />\n          <div className=\"absolute top-2 left-2 w-1.5 h-1.5 rounded-full bg-white/10\" />\n          <div className=\"absolute top-2 right-2 w-1.5 h-1.5 rounded-full bg-white/10\" />\n          <div className=\"absolute bottom-2 left-2 w-1.5 h-1.5 rounded-full bg-white/10\" />\n          <div className=\"absolute bottom-2 right-2 w-1.5 h-1.5 rounded-full bg-white/10\" />\n\n          {/* Stepper progress indicator header */}\n          {step < 4 && !isCompiling && (\n            <div className=\"flex items-center justify-between mb-8 pb-6 border-b border-white/5\">\n              <span className=\"text-[10px] font-mono text-gray-400\">\n                GARC\303\215A COMM-GATE v2.0\n              </span>\n              \n              <div className=\"flex gap-2\">\n                {[0, 1, 2, 3].map((s) => (\n                  <div\n                    key={s}\n                    className={`h-1.5 rounded-full transition-all duration-300 ${\n                      s === step\n                        ? \"w-8 bg-cyber-cyan\"\n                        : s < step\n                        ? \"w-2 bg-cyber-green\"\n                        : \"w-2 bg-white/10\"\n                    }`}\n                  />\n                ))}\n              </div>\n            </div>\n          )}\n\n          {/* DYNAMIC PROGRESS IN COMPILATION */}\n          {isCompiling ? (\n            <div className=\"my-auto font-mono text-xs text-glow-green text-left flex flex-col justify-center min-h-[220px]\">\n              <div className=\"flex items-center gap-3 mb-6\">\n                <RefreshCw className=\"w-5 h-5 text-cyber-green animate-spin\" />\n                <span className=\"text-gray-400 text-[10px] tracking-widest uppercase\">Compilando Solicitud S\303\263nica</span>\n              </div>\n              \n              <div className=\"space-y-2 bg-black/60 p-5 rounded-2xl border border-white/5 min-h-[160px] text-[11px] leading-relaxed text-gray-300\">\n                {compilingLogs.map((log, lIdx) => (\n                  <motion.p\n                    key={lIdx}\n                    initial={{ opacity: 0, x: -5 }}\n                    animate={{ opacity: 1, x: 0 }}\n                    transition={{ duration: 0.15 }}\n                  >\n                    {log}\n                  </motion.p>\n                ))}\n              </div>\n            </div>\n          ) : (\n            <div className=\"my-auto min-h-[180px] flex flex-col justify-center\">\n              <AnimatePresence mode=\"wait\">\n                {/* STEP 0: NAME INTRO */}\n                {step === 0 && (\n                  <motion.div\n                    key=\"step0\"\n                    initial={{ opacity: 0, x: 15 }}\n                    animate={{ opacity: 1, x: 0 }}\n                    exit={{ opacity: 0, x: -15 }}\n                    transition={{ duration: 0.35 }}\n                    className=\"space-y-5 text-left\"\n                  >\n                    <label className=\"text-xs font-mono text-cyber-cyan uppercase tracking-widest flex items-center gap-2\">\n                      <Sparkles className=\"w-3.5 h-3.5\" /> 01. Saludo Inicial\n                    </label>\n                    \n                    <h3 className=\"text-2xl md:text-3xl font-display text-white font-medium leading-tight\">\n                      Hola. Bienvenido a Garc\303\255a M\303\272sica. <br className=\"hidden md:inline\" />\n                      \302\277C\303\263mo debemos llamarte en el estudio?\n                    </h3>\n                    \n                    <div className=\"flex items-center gap-4 border-b border-white/20 focus-within:border-cyber-cyan transition-all py-3 group\">\n                      <input\n                        type=\"text\"\n                        placeholder=\"Ingresa tu nombre o alias art\303\255stico...\"\n                        value={formData.name}\n                        onChange={(e) => {\n                          setFormData({ ...formData, name: e.target.value });\n                          setErrorMsg(\"\");\n                        }}\n                        onKeyDown={(e) => { if (e.key === \"Enter\") handleNextStep(); }}\n                        className=\"bg-transparent border-none text-white outline-none w-full text-lg placeholder-white/35 font-light\"\n                        autoFocus\n                      />\n                      <span className=\"text-[10px] font-mono text-gray-500 uppercase flex items-center gap-1 shrink-0\">\n                        Enter <CornerDownLeft className=\"w-3 h-3 text-gray-500\" />\n                      </span>\n                    </div>\n                  </motion.div>\n                )}\n\n                {/* STEP 1: SERVICE SELECTION */}\n                {step === 1 && (\n                  <motion.div\n                    key=\"step1\"\n                    initial={{ opacity: 0, x: 15 }}\n                    animate={{ opacity: 1, x: 0 }}\n                    exit={{ opacity: 0, x: -15 }}\n                    transition={{ duration: 0.35 }}\n                    className=\"space-y-5 text-left\"\n                  >\n                    <label className=\"text-xs font-mono text-cyber-violet uppercase tracking-widest\">\n                      02. Planificaci\303\263n\n                    </label>\n                    <h3 className=\"text-2xl md:text-3xl font-display text-white font-medium leading-tight\">\n                      Gusto en saludarte, <span className=\"text-cyber-violet\">{formData.name}</span>. <br />\n                      \302\277Qu\303\251 tipo de proceso s\303\263nico requiere tu proyecto?\n                    </h3>\n                    \n                    <div className=\"grid grid-cols-1 md:grid-cols-2 gap-3 pt-2 font-sans\">\n                      {[\n                        { label: \"\360\237\216\233\357\270\217 Mezcla H\303\255brida Est\303\251reo\", name: \"Mezcla H\303\255brida Est\303\251reo\" },\n                        { label: \"\360\237\223\200 Producci\303\263n Completa de Cero\", name: \"Producci\303\263n Completa\" },\n                        { label: \"\360\237\222\245 Masterizaci\303\263n de Presi\303\263n\", name: \"Masterizaci\303\263n de Presi\303\263n\" },\n                        { label: \"\342\232\241 Otro (Asesor\303\255a / Post-Co)\", name: \"Proyecto H\303\255brido\" }\n                      ].map((item) => (\n                        <button\n                          key={item.name}\n                          onClick={() => selectService(item.name)}\n                          className={`p-4 rounded-xl text-left border cursor-pointer text-xs md:text-sm font-medium transition-all ${\n                            formData.service === item.name\n                              ? \"bg-cyber-violet/10 border-cyber-violet text-white\"\n                              : \"bg-white/[0.01] border-white/5 text-gray-300 hover:bg-white/[0.02] hover:border-white/12\"\n                          }`}\n                        >\n                          {item.label}\n                        </button>\n                      ))}\n                    </div>\n                  </motion.div>\n                )}\n\n                {/* STEP 2: BUDGET BRACKETS */}\n                {step === 2 && (\n                  <motion.div\n                    key=\"step2\"\n                    initial={{ opacity: 0, x: 15 }}\n                    animate={{ opacity: 1, x: 0 }}\n                    exit={{ opacity: 0, x: -15 }}\n                    transition={{ duration: 0.35 }}\n                    className=\"space-y-5 text-left\"\n                  >\n                    <label className=\"text-xs font-mono text-cyber-green uppercase tracking-widest\">\n                      03. Rango de Presupuesto\n                    </label>\n                    <h3 className=\"text-2xl md:text-3xl font-display text-white font-medium leading-tight\">\n                      Excelente elecci\303\263n para {formData.service}. \302\277Cu\303\241l es la escala estimada de presupuesto de tu canci\303\263n?\n                    </h3>\n                    \n                    <div className=\"grid grid-cols-1 md:grid-cols-3 gap-3 pt-2\">\n                      {[\n                        { val: \"Art\303\255stico Sencillo (<$400)\", label: \"Artesanal / Single\", desc: \"Mezcla u Optimizaci\303\263n\" },\n                        { val: \"Est\303\241ndar Sello ($400-$1200)\", label: \"Est\303\241ndar Indie\", desc: \"Producci\303\263n / Mezcla + M\303\241ster\" },\n                        { val: \"Label Premium ($1200+)\", label: \"Label / Corporativo\", desc: \"Producci\303\263n Ejecutiva + Campa\303\261a\" }\n                      ].map((item) => (\n                        <button\n                          key={item.val}\n                          onClick={() => selectBudget(item.val)}\n                          className={`p-4 rounded-xl text-left border cursor-pointer transition-all flex flex-col justify-between h-[110px] ${\n                            formData.budget === item.val\n                              ? \"bg-cyber-green/5 border-cyber-green text-white\"\n                              : \"bg-white/[0.01] border-white/5 text-gray-350 hover:bg-white/[0.02] hover:border-white/12\"\n                          }`}\n                        >\n                          <div>\n                            <span className=\"text-[12px] font-bold text-white block\">{item.label}</span>\n                            <span className=\"text-[10px] text-gray-400 mt-1 block\">{item.desc}</span>\n                          </div>\n                          <span className=\"text-[11px] font-mono text-cyber-green uppercase tracking-wider\">{item.val}</span>\n                        </button>\n                      ))}\n                    </div>\n                  </motion.div>\n                )}\n\n                {/* STEP 3: CONTACT EMAIL & NOTES */}\n                {step === 3 && (\n                  <motion.div\n                    key=\"step3\"\n                    initial={{ opacity: 0, x: 15 }}\n                    animate={{ opacity: 1, x: 0 }}\n                    exit={{ opacity: 0, x: -15 }}\n                    transition={{ duration: 0.35 }}\n                    className=\"space-y-5 text-left\"\n                  >\n                    <label className=\"text-xs font-mono text-white/50 uppercase tracking-widest\">\n                      04. Canales de Enlace\n                    </label>\n                    <h3 className=\"text-2xl md:text-3xl font-display text-white font-medium leading-tight\">\n                      \302\241Casi listo! \302\277En qu\303\251 correo electr\303\263nico debemos enviarte la cotizaci\303\263n y agendar la llamada gratuita de 15 min?\n                    </h3>\n                    \n                    <div className=\"flex items-center gap-4 border-b border-white/20 focus-within:border-white transition-all py-3\">\n                      <input\n                        type=\"email\"\n                        placeholder=\"tu-correo@plataforma.com\"\n                        value={formData.email}\n                        onChange={(e) => {\n                          setFormData({ ...formData, email: e.target.value });\n                          setErrorMsg(\"\");\n                        }}\n                        onKeyDown={(e) => { if (e.key === \"Enter\") handleNextStep(); }}\n                        className=\"bg-transparent border-none text-white outline-none w-full text-lg placeholder-white/25 font-light\"\n                        autoFocus\n                      />\n                    </div>\n\n                    <div className=\"pt-2\">\n                      <p className=\"text-[10px] font-mono text-gray-500 uppercase tracking-widest mb-1\">Notas del proyecto (opcional):</p>\n                      <textarea\n                        placeholder=\"Dinos m\303\241s de tus influencias (Ableton, sintetizadores, referencias sutiles, influencias)\"\n                        value={formData.comments}\n                        onChange={(e) => setFormData({ ...formData, comments: e.target.value })}\n                        className=\"w-full h-16 bg-white/[0.02] border border-white/5 rounded-xl p-3 outline-none text-xs text-white placeholder-white/10 resize-none focus:border-white/15\"\n                      />\n                    </div>\n                  </motion.div>\n                )}\n\n                {/* STEP 4: SUCCESS LOGOUT CARD */}\n                {step === 4 && (\n                  <motion.div\n                    key=\"step4\"\n                    initial={{ opacity: 0, scale: 0.95 }}\n                    animate={{ opacity: 1, scale: 1 }}\n                    transition={{ duration: 0.4 }}\n                    className=\"space-y-6 text-center\"\n                  >\n                    <div className=\"w-16 h-16 rounded-full bg-cyber-green/10 border border-cyber-green flex items-center justify-center mx-auto text-cyber-green animate-bounce\">\n                      <ShieldCheck className=\"w-8 h-8 text-cyber-green\" />\n                    </div>\n                    \n                    <div className=\"max-w-md mx-auto\">\n                      <h3 className=\"text-3xl font-display font-medium text-white mb-3\">\n                        \302\241Se\303\261al Transmitida!\n                      </h3>\n                      <p className=\"text-gray-400 text-sm font-light leading-relaxed mb-6\">\n                        Hemos recibido con \303\251xito tu solicitud de <strong>{formData.service}</strong>, estimado <strong>{formData.name}</strong>. Nuestro sumador s\303\263nico ya reserv\303\263 un bloque de pre-revisi\303\263n t\303\251cnica. Estaremos envi\303\241ndote un correo a <strong>{formData.email}</strong> en las pr\303\263ximas 24-48 horas.\n                      </p>\n                    </div>\n\n                    <div className=\"flex justify-center border-t border-white/5 pt-6 select-none font-mono text-[10px] space-x-6 text-gray-500\">\n                      <p className=\"flex items-center gap-1\">\n                        <Cpu className=\"w-3 h-3 text-cyber-green\" /> SSL-LINK INYECTADO\n                      </p>\n                      <p className=\"flex items-center gap-1\">\n                        <Volume2 className=\"w-3 h-3 text-cyber-cyan\" /> 192KHZ PROCESSED\n                      </p>\n                    </div>\n\n                    <button\n                      onClick={resetForm}\n                      className=\"inline-flex items-center gap-2 text-[10px] font-mono hover:text-cyber-purple text-gray-450 uppercase cursor-pointer border border-white/5 hover:border-white/12 px-4 py-2 bg-white/[0.01] hover:bg-white/5 rounded-lg active:scale-95 transition-all\"\n                    >\n                      Volver a empezar sesi\303\263n\n                    </button>\n                  </motion.div>\n                )}\n              </AnimatePresence>\n            </div>\n          )}\n\n          {/* Stepper Footer Controls */}\n          {step < 4 && !isCompiling && (\n            <div className=\"flex items-center justify-between mt-8 pt-6 border-t border-white/5\">\n              {/* Error log placeholder */}\n              <div className=\"text-left\">\n                {errorMsg ? (\n                  <p className=\"text-xs font-mono text-red-400 animate-pulse\">\n                    \342\232\240 ERR: {errorMsg}\n                  </p>\n                ) : (\n                  <p className=\"text-[10px] font-mono text-gray-600\">\n                    STATUS: READY_FOR_SIGNAL\n                  </p>\n                )}\n              </div>\n\n              {/* Controls */}\n              <div className=\"flex gap-4\">\n                {step > 0 && (\n                  <button\n                    onClick={handlePrevStep}\n                    className=\"px-5 py-2.5 rounded-lg border border-white/5 text-[10px] uppercase font-mono tracking-wider text-gray-400 hover:text-white hover:border-white/15 transition-all cursor-pointer\"\n                  >\n                    Atr\303\241s\n                  </button>\n                )}\n\n                <button\n                  onClick={handleNextStep}\n                  className=\"px-6 py-2.5 rounded-lg bg-white text-black font-mono text-[10px] uppercase tracking-widest font-bold hover:bg-cyber-cyan hover:shadow-cyber-cyan/30 transition-all duration-300 flex items-center justify-center gap-2 cursor-pointer\"\n                >\n                  {step === 3 ? (\n                    <>\n                      Enviar <Send className=\"w-3.5 h-3.5 fill-black\" />\n                    </>\n                  ) : (\n                    <>\n                      Siguiente <ArrowRight className=\"w-3.5 h-3.5\" />\n                    </>\n                  )}\n                </button>\n              </div>\n            </div>\n          )}\n\n        </div>\n      </div>\n    </section>\n  );\n}\n"
