        }
        lines {
          text: "      bassStepTrigger = true;"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      noteIndex = step % 2 === 0 ? 0 : 5; // jumping fifths/octaves"
