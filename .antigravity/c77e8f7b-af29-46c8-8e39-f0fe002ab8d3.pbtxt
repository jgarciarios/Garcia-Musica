        lines {
          text: "    }"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    "
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    if (leadStepTrigger) {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      const leadFreq = getFreqFromScale(baseFrequency * 2, melodyIndex, scaleType);"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      playLead(time, leadFreq, secondsPerStep * 1.6, scaleType === \"major\");"
