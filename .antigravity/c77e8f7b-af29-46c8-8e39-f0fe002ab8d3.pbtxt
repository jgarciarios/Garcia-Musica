  file_change {
    absolute_path_uri: "file:///src/index.css"
    file_change_type: FILE_CHANGE_TYPE_EDIT
    replacement_chunks {
      target_content: "@import \"tailwindcss\";"
      replacement_content: "@import url(\'https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap\');\n@import \"tailwindcss\";\n\n@theme {\n  --font-sans: \"Inter\", ui-sans-serif, system-ui, sans-serif;\n  --font-display: \"Space Grotesk\", sans-serif;\n  --font-mono: \"JetBrains Mono\", ui-monospace, monospace;\n\n  /* Custom colors matching the cinematic dark cyber theme */\n  --color-cyber-green: #10b981;    /* emerald-500 */\n  --color-cyber-violet: #8b5cf6;   /* violet-500 */\n  --color-cyber-cyan: #06b6d4;     /* cyan-500 */\n  --color-neon-green: #39ff14;\n  --color-neon-purple: #bf55ec;\n}\n\n@layer base {\n  body {\n    background-color: #030303;\n    color: #f3f4f6;\n    font-family: var(--font-sans);\n    overflow-x: hidden;\n  }\n\n  /* Custom high-tech scrollbar */\n  ::-webkit-scrollbar {\n    width: 6px;\n    height: 6px;\n  }\n  ::-webkit-scrollbar-track {\n    background: #080808;\n  }\n  ::-webkit-scrollbar-thumb {\n    background: #1a1a24;\n    border-radius: 3px;\n  }\n  ::-webkit-scrollbar-thumb:hover {\n    background: #323246;\n  }\n}\n\n/* Custom premium visual styles */\n.neon-glow-green {\n  box-shadow: 0 0 25px rgba(16, 185, 129, 0.2);\n}\n\n.neon-glow-violet {\n  box-shadow: 0 0 25px rgba(139, 92, 246, 0.2);\n}\n\n.neon-glow-cyan {\n  box-shadow: 0 0 25px rgba(6, 182, 212, 0.2);\n}\n\n.text-glow-green {\n  text-shadow: 0 0 8px rgba(16, 185, 129, 0.5);\n}\n\n.text-glow-violet {\n  text-shadow: 0 0 8px rgba(139, 92, 246, 0.5);\n}\n\n.text-glow-cyan {\n  text-shadow: 0 0 8px rgba(6, 182, 212, 0.5);\n}\n\n/* Glassmorphism backgrounds for Ableton-style controllers */\n.glass-panel {\n  background: rgba(10, 10, 14, 0.82);\n  backdrop-filter: blur(16px);\n  border: 1px solid rgba(255, 255, 255, 0.05);\n}\n\n.glass-panel-heavy {\n  background: rgba(6, 6, 8, 0.94);\n  backdrop-filter: blur(24px);\n  border: 1px solid rgba(255, 255, 255, 0.08);\n}\n\n/* Grid overlay background to simulate digital console */\n.grid-mesh {\n  background-size: 40px 40px;\n  background-image: \n    linear-gradient(to right, rgba(255, 255, 255, 0.015) 1px, transparent 1px),\n    linear-gradient(to bottom, rgba(255, 255, 255, 0.015) 1px, transparent 1px);\n}\n\n/* Radial cyber glow spotlight */\n.cyber-spotlight-violet {\n  background: radial-gradient(800px circle at var(--x, 50%) var(--y, 50%), rgba(139, 92, 246, 0.1), transparent 80%);\n}\n\n.cyber-spotlight-green {\n  background: radial-gradient(600px circle at var(--x, 50%) var(--y, 50%), rgba(16, 185, 129, 0.08), transparent 80%);\n}\n\n/* Equalizer micro-animations */\n@keyframes eq-scale-1 {\n  0%, 100% { transform: scaleY(0.2); }\n  50% { transform: scaleY(0.85); }\n}\n@keyframes eq-scale-2 {\n  0%, 100% { transform: scaleY(0.4); }\n  50% { transform: scaleY(0.95); }\n}\n@keyframes eq-scale-3 {\n  0%, 100% { transform: scaleY(0.1); }\n  50% { transform: scaleY(0.7); }\n}\n@keyframes eq-scale-4 {\n  0%, 100% { transform: scaleY(0.3); }\n  50% { transform: scaleY(1.0); }\n}\n\n.eq-anim-1 { animation: eq-scale-1 1s ease-in-out infinite; }\n.eq-anim-2 { animation: eq-scale-2 1.4s ease-in-out infinite; }\n.eq-anim-3 { animation: eq-scale-3 0.8s ease-in-out infinite; }\n.eq-anim-4 { animation: eq-scale-4 1.2s ease-in-out infinite; }\n"
    }
