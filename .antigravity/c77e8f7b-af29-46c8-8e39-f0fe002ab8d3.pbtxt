  file_change {
    absolute_path_uri: "file:///src/components/AudioPlayer.tsx"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "import { useState, useEffect, useRef } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport { TRACKS } from \"../data\";\nimport { StemTrack } from \"../types\";\nimport { studioSynth } from \"../lib/synth\";\nimport { Play, Pause, Sliders, Volume2, Music, Activity, Hammer } from \"lucide-react\";\n\nexport default function AudioPlayer() {\n  const [selectedTrack, setSelectedTrack] = useState<StemTrack>(TRACKS[0]);\n  const [isPlaying, setIsPlaying] = useState<boolean>(false);\n  const [bpm, setBpm] = useState<number>(TRACKS[0].bpm);\n  const [currentStep, setCurrentStep] = useState<number>(-1);\n  const [stems, setStems] = useState({\n    drums: true,\n    bass: true,\n    lead: true,\n    space: true,\n  });\n\n  // XY Pad coordinates (percentages 0-1)\n  const [xyVal, setXyVal] = useState({ x: 0.6, y: 0.4 });\n  const xyPadRef = useRef<HTMLDivElement>(null);\n  const isDraggingXY = useRef<boolean>(false);\n\n  // Canvas visualizer reference\n  const canvasRef = useRef<HTMLCanvasElement>(null);\n  const animationFrameId = useRef<number>(-1);\n\n  // Clean up on unmount\n  useEffect(() => {\n    return () => {\n      studioSynth.stop();\n      if (animationFrameId.current) {\n        cancelAnimationFrame(animationFrameId.current);\n      }\n    };\n  }, []);\n\n  // Update track properties on track swap\n  const handleTrackChange = (track: StemTrack) => {\n    const wasPlaying = isPlaying;\n    if (isPlaying) {\n      studioSynth.stop();\n      setIsPlaying(false);\n      setCurrentStep(-1);\n    }\n    setSelectedTrack(track);\n    setBpm(track.bpm);\n    // Keep default stems active\n    const defaultStems = { drums: true, bass: true, lead: true, space: true };\n    setStems(defaultStems);\n    \n    // Auto play if it was already playing\n    if (wasPlaying) {\n      setTimeout(() => {\n        studioSynth.play(track.id, track.bpm, track.baseFreq, defaultStems, (step) => {\n          setCurrentStep(step);\n        });\n        setIsPlaying(true);\n        // Force filter update\n        studioSynth.updateXYFilter(xyVal.x, xyVal.y);\n      }, 50);\n    }\n  };\n\n  // Toggle master synthesiser play\n  const handleTogglePlay = () => {\n    if (isPlaying) {\n      studioSynth.stop();\n      setIsPlaying(false);\n      setCurrentStep(-1);\n    } else {\n      studioSynth.play(selectedTrack.id, bpm, selectedTrack.baseFreq, stems, (step) => {\n        setCurrentStep(step);\n      });\n      setIsPlaying(true);\n      // set filter immediately\n      studioSynth.updateXYFilter(xyVal.x, xyVal.y);\n    }\n  };\n\n  // Toggle single stem on/off\n  const toggleStem = (stemName: keyof typeof stems) => {\n    const updatedStems = {\n      ...stems,\n      [stemName]: !stems[stemName],\n    };\n    setStems(updatedStems);\n    studioSynth.updateStems(updatedStems);\n  };\n\n  // Handle BPM slider change\n  const handleBpmChange = (newBpm: number) => {\n    setBpm(newBpm);\n    studioSynth.updateBpm(newBpm);\n  };\n\n  // Handle XY pad mouse/touch events\n  const handleXYUpdate = (clientX: number, clientY: number) => {\n    if (!xyPadRef.current) return;\n    const rect = xyPadRef.current.getBoundingClientRect();\n    let x = (clientX - rect.left) / rect.width;\n    let y = 1 - (clientY - rect.top) / rect.height; // Invert to make bottom left the origin\n\n    // Constrain range 0 to 1\n    x = Math.max(0, Math.min(1, x));\n    y = Math.max(0, Math.min(1, y));\n\n    setXyVal({ x, y });\n    studioSynth.updateXYFilter(x, y);\n  };\n\n  const handleXYMouseDown = (e: React.MouseEvent) => {\n    isDraggingXY.current = true;\n    handleXYUpdate(e.clientX, e.clientY);\n  };\n\n  // Listen globally for mouse up/move to keep drag smooth\n  useEffect(() => {\n    const handleGlobalMouseMove = (e: MouseEvent) => {\n      if (!isDraggingXY.current) return;\n      handleXYUpdate(e.clientX, e.clientY);\n    };\n\n    const handleGlobalMouseUp = () => {\n      isDraggingXY.current = false;\n    };\n\n    window.addEventListener(\"mousemove\", handleGlobalMouseMove);\n    window.addEventListener(\"mouseup\", handleGlobalMouseUp);\n\n    return () => {\n      window.removeEventListener(\"mousemove\", handleGlobalMouseMove);\n      window.removeEventListener(\"mouseup\", handleGlobalMouseUp);\n    };\n  }, [xyVal]);\n\n  // Touch handlers\n  const handleXYTouchStart = (e: React.TouchEvent) => {\n    isDraggingXY.current = true;\n    if (e.touches.length > 0) {\n      handleXYUpdate(e.touches[0].clientX, e.touches[0].clientY);\n    }\n  };\n\n  const handleXYTouchMove = (e: React.TouchEvent) => {\n    if (!isDraggingXY.current) return;\n    if (e.touches.length > 0) {\n      handleXYUpdate(e.touches[0].clientX, e.touches[0].clientY);\n    }\n  };\n\n  // Canvas Drawing loop\n  useEffect(() => {\n    const canvas = canvasRef.current;\n    if (!canvas) return;\n    const ctx = canvas.getContext(\"2d\");\n    if (!ctx) return;\n\n    let time = 0;\n\n    const draw = () => {\n      const width = canvas.width;\n      const height = canvas.height;\n      \n      // Black fade trail for sci-fi look\n      ctx.fillStyle = \"rgba(4, 4, 6, 0.25)\";\n      ctx.fillRect(0, 0, width, height);\n\n      const analyser = studioSynth.getAnalyser();\n\n      if (isPlaying && analyser) {\n        // Draw real Web Audio spectrum\n        const bufferLength = analyser.frequencyBinCount;\n        const dataArray = new Uint8Array(bufferLength);\n        \n        analyser.getByteFrequencyData(dataArray);\n\n        // Wave color based on selected track theme\n        const glowColor =\n          selectedTrack.color === \"cyan\"\n            ? \"rgba(6, 182, 212,\"\n            : selectedTrack.color === \"violet\"\n            ? \"rgba(139, 92, 246,\"\n            : \"rgba(16, 185, 129,\";\n\n        const barWidth = (width / bufferLength) * 1.5;\n        let x = 0;\n\n        ctx.beginPath();\n        for (let i = 0; i < bufferLength; i++) {\n          const percent = dataArray[i] / 255;\n          const barHeight = percent * height * 0.9;\n\n          // Draw neon glowing bars or lines\n          ctx.strokeStyle = `${glowColor} ${0.3 + percent * 0.7})`;\n          ctx.lineWidth = 2.5;\n          ctx.lineTo(x, height - barHeight - 10);\n\n          x += barWidth;\n        }\n        ctx.stroke();\n\n        // Time domain wave on top\n        const timeData = new Uint8Array(bufferLength);\n        analyser.getByteTimeDomainData(timeData);\n        ctx.beginPath();\n        ctx.lineWidth = 1.5;\n        ctx.strokeStyle =\n          selectedTrack.color === \"cyan\"\n            ? \"#22d3ee\"\n            : selectedTrack.color === \"violet\"\n            ? \"#a78bfa\"\n            : \"#34d399\";\n        \n        const sliceWidth = width / bufferLength;\n        let tx = 0;\n        \n        for (let i = 0; i < bufferLength; i++) {\n          const v = timeData[i] / 128.0;\n          const ty = (v * height) / 2;\n          \n          if (i === 0) {\n            ctx.moveTo(tx, ty);\n          } else {\n            ctx.lineTo(tx, ty);\n          }\n          tx += sliceWidth;\n        }\n        ctx.lineTo(width, height / 2);\n        ctx.stroke();\n\n      } else {\n        // Simulated beautiful modular ambient waves when paused\n        time += 0.02;\n        ctx.beginPath();\n        ctx.lineWidth = 2;\n        \n        // Pick primary color based on track\n        const mainColor = \n          selectedTrack.color === \"cyan\" ? \"#06b6d4\" : \n          selectedTrack.color === \"violet\" ? \"#8b5cf6\" : \"#10b981\";\n        \n        ctx.strokeStyle = mainColor;\n\n        for (let x = 0; x < width; x++) {\n          // Multiple sine superposition to look like oscilloscope\n          const y =\n            height / 2 +\n            Math.sin(x * 0.008 + time) * 15 * Math.sin(time * 0.5) +\n            Math.cos(x * 0.02 - time * 0.8) * 8;\n          \n          if (x === 0) {\n            ctx.moveTo(0, y);\n          } else {\n            ctx.lineTo(x, y);\n          }\n        }\n        ctx.stroke();\n\n        // Draw a secondary dimmer high-freq wave\n        ctx.beginPath();\n        ctx.lineWidth = 1;\n        ctx.strokeStyle = \n          selectedTrack.color === \"cyan\" ? \"rgba(6, 182, 212, 0.25)\" : \n          selectedTrack.color === \"violet\" ? \"rgba(139, 92, 246, 0.25)\" : \"rgba(16, 185, 129, 0.25)\";\n        \n        for (let x = 0; x < width; x++) {\n          const y =\n            height / 2 +\n            Math.sin(x * 0.025 - time) * 8 * Math.cos(time * 0.1) +\n            Math.sin(x * 0.05 + time) * 4;\n          \n          if (x === 0) {\n            ctx.moveTo(0, y);\n          } else {\n            ctx.lineTo(x, y);\n          }\n        }\n        ctx.stroke();\n      }\n\n      animationFrameId.current = requestAnimationFrame(draw);\n    };\n\n    draw();\n\n    return () => {\n      cancelAnimationFrame(animationFrameId.current);\n    };\n  }, [isPlaying, selectedTrack]);\n\n  // Color mappings for Tailwind conditional styles\n  const textColorsMap = {\n    cyan: \"text-cyber-cyan\",\n    violet: \"text-cyber-violet\",\n    green: \"text-cyber-green\"\n  };\n\n  const bgColorsMap = {\n    cyan: \"bg-cyber-cyan\",\n    violet: \"bg-cyber-violet\",\n    green: \"bg-cyber-green\"\n  };\n\n  const glowColorsMap = {\n    cyan: \"neon-glow-cyan border-cyber-cyan/30\",\n    violet: \"neon-glow-violet border-cyber-violet/30\",\n    green: \"neon-glow-green border-cyber-green/30\"\n  };\n\n  return (\n    <section id=\"portfolio\" className=\"relative py-24 px-4 bg-black/60 scroll-mt-12\">\n      <div className=\"absolute inset-0 grid-mesh opacity-40 pointer-events-none\" />\n      \n      <div className=\"max-w-6xl mx-auto z-10 relative\">\n        {/* Section Title */}\n        <div className=\"text-center mb-16\">\n          <span className=\"text-xs font-mono tracking-widest text-cyber-cyan\">\n            [ MULTI-STEM INTERACTIVE PLAYER ]\n          </span>\n          <h2 className=\"text-3xl md:text-5xl font-display font-medium text-white tracking-tight mt-2\">\n            CONSOLA DE MUESTRA\n          </h2>\n          <p className=\"text-gray-400 text-sm md:text-base mt-4 max-w-xl mx-auto font-light leading-relaxed\">\n            Interact\303\272a directamente con nuestro motor de s\303\255ntesis experimental. Modifica los canales BPM, apaga canales (stems) y mu\303\251vete en la zona de filtro a continuaci\303\263n.\n          </p>\n        </div>\n\n        {/* Console layout */}\n        <div className=\"grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch font-sans\">\n          \n          {/* TRACK SELECTOR LEFT - 4 cols */}\n          <div className=\"col-span-1 lg:col-span-4 flex flex-col gap-4\">\n            <h3 className=\"text-xs font-mono text-gray-500 uppercase tracking-widest px-1\">\n              Seleccionar Track\n            </h3>\n\n            <div className=\"flex flex-col gap-3\">\n              {TRACKS.map((track) => {\n                const isSelected = selectedTrack.id === track.id;\n                return (\n                  <button\n                    key={track.id}\n                    onClick={() => handleTrackChange(track)}\n                    className={`p-5 rounded-2xl text-left border cursor-pointer transition-all duration-300 relative overflow-hidden group ${\n                      isSelected\n                        ? `bg-white/[0.03] ${selectedTrack.color === \"cyan\" ? \"border-cyber-cyan/50\" : selectedTrack.color === \"violet\" ? \"border-cyber-violet/50\" : \"border-cyber-green/50\"}`\n                        : \"bg-white/[0.01] border-white/5 hover:bg-white/[0.02] hover:border-white/10\"\n                    }`}\n                  >\n                    {/* Glowing side accent */}\n                    {isSelected && (\n                      <span\n                        className={`absolute left-0 top-0 bottom-0 w-1.5 ${\n                          track.color === \"cyan\" ? \"bg-cyber-cyan text-glow-cyan\" : track.color === \"violet\" ? \"bg-cyber-violet text-glow-violet\" : \"bg-cyber-green text-glow-green\"\n                        }`}\n                      />\n                    )}\n\n                    <div className=\"flex justify-between items-start\">\n                      <span className=\"text-[10px] font-mono text-gray-500 uppercase tracking-wider\">\n                        {track.genre}\n                      </span>\n                      <span className=\"text-[11px] font-mono text-gray-400 font-light bg-white/5 px-2 py-0.5 rounded\">\n                        {track.bpm} BPM\n                      </span>\n                    </div>\n\n                    <h4 className=\"text-lg font-display font-medium text-white mt-1\">\n                      {track.title}\n                    </h4>\n\n                    <p className=\"text-xs text-gray-400 font-light leading-snug mt-2\">\n                      {track.description}\n                    </p>\n\n                    <div className=\"flex items-center gap-4 mt-4 text-[11px] font-mono text-gray-500\">\n                      <span>Tono: {track.key}</span>\n                      <span>\342\200\242</span>\n                      <span>Duraci\303\263n: {track.duration}</span>\n                    </div>\n                  </button>\n                );\n              })}\n            </div>\n            \n            <div className=\"glass-panel p-4 rounded-xl border border-white/5 font-mono text-[10px] text-gray-500 flex items-center gap-3\">\n              <span className=\"flex h-2.5 w-2.5 rounded-full bg-cyber-green animate-pulse\" />\n              <span>S\303\215NTESIS GENERATIVA LOCAL CON AUDIO CONTEXT API PASANDO POR FILTROS BIQUAD</span>\n            </div>\n          </div>\n\n          {/* MAIN CONSOLE CENTER & RIGHT - 8 cols */}\n          <div className={`col-span-1 lg:col-span-8 glass-panel-heavy p-6 md:p-8 rounded-3xl border transition-all duration-700 flex flex-col justify-between ${\n            isPlaying ? glowColorsMap[selectedTrack.color as keyof typeof glowColorsMap] : \"border-white/5\"\n          }`}>\n            \n            {/* Header: Track Status Indicator */}\n            <div className=\"flex flex-col md:flex-row md:items-center justify-between pb-6 border-b border-white/5 gap-4\">\n              <div className=\"flex items-center gap-4\">\n                <button\n                  onClick={handleTogglePlay}\n                  className={`w-14 h-14 rounded-full flex items-center justify-center cursor-pointer transition-all duration-300 ${\n                    isPlaying\n                      ? \"bg-white text-black hover:bg-white/90 scale-95\"\n                      : `${bgColorsMap[selectedTrack.color as keyof typeof bgColorsMap]} text-black hover:opacity-95 shadow-lg`\n                  }`}\n                >\n                  {isPlaying ? (\n                    <Pause className=\"w-6 h-6 fill-black\" />\n                  ) : (\n                    <Play className=\"w-6 h-6 fill-black translate-x-0.5\" />\n                  )}\n                </button>\n\n                <div>\n                  <h3 className=\"font-display font-medium text-lg text-white\">\n                    {selectedTrack.title}\n                  </h3>\n                  <div className=\"flex items-center gap-2 mt-0.5\">\n                    <span className=\"text-xs font-mono text-gray-500\">CONSOLA:</span>\n                    <span className={`text-xs font-mono uppercase ${textColorsMap[selectedTrack.color as keyof typeof textColorsMap]}`}>\n                      {isPlaying ? \"Transmitiendo Se\303\261al\" : \"Listo para arrancar\"}\n                    </span>\n                  </div>\n                </div>\n              </div>\n\n              {/* Pitch Stretch BPM block */}\n              <div className=\"flex items-center gap-4 bg-white/[0.02] border border-white/5 p-3 rounded-xl\">\n                <div className=\"text-right\">\n                  <p className=\"text-[9px] font-mono text-gray-500 uppercase\">Tempo Stretch</p>\n                  <p className=\"text-sm font-mono text-white font-semibold\">{bpm} <span className=\"text-gray-500 text-xs\">BPM</span></p>\n                </div>\n                <input\n                  type=\"range\"\n                  min=\"60\"\n                  max=\"180\"\n                  value={bpm}\n                  onChange={(e) => handleBpmChange(Number(e.target.value))}\n                  className=\"w-24 md:w-32 h-1 bg-white/10 rounded-lg appearance-none cursor-pointer accent-white\"\n                />\n              </div>\n            </div>\n\n            {/* Visualizer Area */}\n            <div className=\"my-6 relative border border-white/5 bg-black/40 rounded-2xl overflow-hidden h-44 flex items-center justify-center\">\n              <canvas\n                ref={canvasRef}\n                width={800}\n                height={176}\n                className=\"w-full h-full block absolute inset-0\"\n              />\n              \n              {/* Overlay telemetry logs */}\n              <div className=\"absolute top-3 left-4 font-mono text-[9px] text-gray-500 space-y-0.5 pointer-events-none\">\n                <p>SIGNAL INTENSITY: {isPlaying ? \"88.2%\" : \"IDLE\"}</p>\n                <p>BITRATE: 320 KBPS FLOAT</p>\n                <p>SPECTRUM RESOLUTION: 128 BIN</p>\n              </div>\n\n              <div className=\"absolute top-3 right-4 font-mono text-[9px] text-cyber-cyan pointer-events-none flex items-center gap-2\">\n                <Activity className=\"w-3 h-3 animate-pulse\" />\n                <span>DYNAMIC ANALYSER</span>\n              </div>\n            </div>\n\n            {/* 16 Step Sequencer Row */}\n            <div className=\"mb-6 bg-white/[0.01] border border-white/5 p-4 rounded-xl font-mono\">\n              <div className=\"flex justify-between items-center text-[9px] text-gray-500 uppercase tracking-widest mb-2.5\">\n                <span>Paso Secuenciador Synth</span>\n                <span className=\"text-white/25\">16-Step Grid</span>\n              </div>\n              \n              <div className=\"grid grid-cols-8 md:grid-cols-16 gap-1.5\">\n                {Array.from({ length: 16 }).map((_, i) => {\n                  const isActive = currentStep === i;\n                  const isBeatQuarter = i % 4 === 0;\n                  \n                  return (\n                    <div\n                      key={i}\n                      className={`h-7 rounded transition-all duration-150 flex items-center justify-center text-[9px] font-bold ${\n                        isActive\n                          ? `${bgColorsMap[selectedTrack.color as keyof typeof bgColorsMap]} text-black text-glow-${selectedTrack.color}`\n                          : isBeatQuarter\n                          ? \"bg-white/[0.08] text-gray-400 border border-white/5\"\n                          : \"bg-white/[0.02] text-gray-650\"\n                      }`}\n                    >\n                      {i + 1}\n                    </div>\n                  );\n                })}\n              </div>\n            </div>\n\n            {/* STEM CONTROLS + XY PAD DUAL GRID */}\n            <div className=\"grid grid-cols-1 md:grid-cols-12 gap-6 items-stretch\">\n              \n              {/* STEMS LEFT: 7 columns */}\n              <div className=\"md:col-span-6 flex flex-col justify-between gap-4\">\n                <div>\n                  <h4 className=\"text-xs font-mono text-gray-500 uppercase tracking-widest mb-3 flex items-center gap-2\">\n                    <Sliders className=\"w-3.5 h-3.5\" /> Canales Mezclador (Stems)\n                  </h4>\n\n                  <div className=\"grid grid-cols-2 gap-3\">\n                    {/* Bater\303\255a stem */}\n                    <button\n                      onClick={() => toggleStem(\"drums\")}\n                      className={`p-3.5 rounded-xl border text-left flex flex-col justify-between transition-all duration-300 cursor-pointer ${\n                        stems.drums\n                          ? `bg-cyber-cyan/5 border-cyber-cyan/35 text-white`\n                          : \"bg-white/[0.01] border-white/5 text-gray-500 hover:border-white/10\"\n                      }`}\n                    >\n                      <span className=\"text-[10px] font-mono uppercase tracking-wider\">01 . RITMO</span>\n                      <div className=\"flex justify-between items-center mt-2.5\">\n                        <span className=\"text-xs font-bold tracking-wide\">\360\237\224\213 BATER\303\215A</span>\n                        <span className={`w-1.5 h-1.5 rounded-full ${stems.drums ? \"bg-cyber-cyan animate-pulse\" : \"bg-gray-700\"}`} />\n                      </div>\n                    </button>\n\n                    {/* Bajo stem */}\n                    <button\n                      onClick={() => toggleStem(\"bass\")}\n                      className={`p-3.5 rounded-xl border text-left flex flex-col justify-between transition-all duration-300 cursor-pointer ${\n                        stems.bass\n                          ? `bg-cyber-violet/5 border-cyber-violet/35 text-white`\n                          : \"bg-white/[0.01] border-white/5 text-gray-500 hover:border-white/10\"\n                      }`}\n                    >\n                      <span className=\"text-[10px] font-mono uppercase tracking-wider\">02 . FONDO</span>\n                      <div className=\"flex justify-between items-center mt-2.5\">\n                        <span className=\"text-xs font-bold tracking-wide\">\360\237\216\270 SUB BAJO</span>\n                        <span className={`w-1.5 h-1.5 rounded-full ${stems.bass ? \"bg-cyber-violet animate-pulse\" : \"bg-gray-700\"}`} />\n                      </div>\n                    </button>\n\n                    {/* Synth Lead stem */}\n                    <button\n                      onClick={() => toggleStem(\"lead\")}\n                      className={`p-3.5 rounded-xl border text-left flex flex-col justify-between transition-all duration-300 cursor-pointer ${\n                        stems.lead\n                          ? `bg-cyber-green/5 border-cyber-green/35 text-white`\n                          : \"bg-white/[0.01] border-white/5 text-gray-500 hover:border-white/10\"\n                      }`}\n                    >\n                      <span className=\"text-[10px] font-mono uppercase tracking-wider\">03 . MELOD\303\215A</span>\n                      <div className=\"flex justify-between items-center mt-2.5\">\n                        <span className=\"text-xs font-bold tracking-wide\">\360\237\216\271 S\303\215NTESIS</span>\n                        <span className={`w-1.5 h-1.5 rounded-full ${stems.lead ? \"bg-cyber-green animate-pulse\" : \"bg-gray-700\"}`} />\n                      </div>\n                    </button>\n\n                    {/* FX Delay space stem */}\n                    <button\n                      onClick={() => toggleStem(\"space\")}\n                      className={`p-3.5 rounded-xl border text-left flex flex-col justify-between transition-all duration-300 cursor-pointer ${\n                        stems.space\n                          ? \"bg-white/[0.04] border-white/30 text-white\"\n                          : \"bg-white/[0.01] border-white/5 text-gray-500 hover:border-white/10\"\n                      }`}\n                    >\n                      <span className=\"text-[10px] font-mono uppercase tracking-wider\">04 . EFECTOS</span>\n                      <div className=\"flex justify-between items-center mt-2.5\">\n                        <span className=\"text-xs font-bold tracking-wide\">\360\237\214\214 ESPACIO</span>\n                        <span className={`w-1.5 h-1.5 rounded-full ${stems.space ? \"bg-white animate-pulse\" : \"bg-gray-700\"}`} />\n                      </div>\n                    </button>\n                  </div>\n                </div>\n\n                <div className=\"bg-white/[0.01] border border-white/5 rounded-xl p-3 flex items-center gap-3\">\n                  <Music className=\"w-5 h-5 text-gray-500 shrink-0\" />\n                  <p className=\"text-[11px] text-gray-400 font-light leading-snug\">\n                    Arrastra el pad de la derecha para esculpir frecuencias de sonido anal\303\263gicas de manera interactiva.\n                  </p>\n                </div>\n              </div>\n\n              {/* XY PAD RIGHT: 7 columns */}\n              <div className=\"md:col-span-6 flex flex-col gap-3\">\n                <div className=\"flex justify-between items-center\">\n                  <h4 className=\"text-xs font-mono text-gray-500 uppercase tracking-widest flex items-center gap-2\">\n                    <Activity className=\"w-3.5 h-3.5\" /> Pad XY Consola\n                  </h4>\n                  <span className=\"text-[10px] font-mono text-gray-400 bg-white/5 px-2 py-0.5 rounded\">\n                    Freq: {Math.floor(80 * Math.pow(16000 / 80, xyVal.x))}Hz | Q: {(0.5 + xyVal.y * 14.5).toFixed(1)}\n                  </span>\n                </div>\n\n                <div\n                  ref={xyPadRef}\n                  onMouseDown={handleXYMouseDown}\n                  onTouchStart={handleXYTouchStart}\n                  onTouchMove={handleXYTouchMove}\n                  className=\"relative h-44 md:h-48 rounded-2xl border border-white/10 overflow-hidden bg-black/85 cursor-crosshair group flex items-center justify-center select-none\"\n                >\n                  {/* Mesh matrix lines */}\n                  <div className=\"absolute inset-0 grid-mesh opacity-20 pointer-events-none\" />\n                  \n                  {/* Axis lines following the dot */}\n                  <div\n                    className=\"absolute left-0 right-0 h-px bg-white/10 pointer-events-none\"\n                    style={{ bottom: `${xyVal.y * 100}%` }}\n                  />\n                  <div\n                    className=\"absolute top-0 bottom-0 w-px bg-white/10 pointer-events-none\"\n                    style={{ left: `${xyVal.x * 100}%` }}\n                  />\n\n                  {/* Filter label guidance */}\n                  <span className=\"absolute bottom-2.5 left-3 text-[8.5px] font-mono text-gray-600 pointer-events-none uppercase\">\n                    \342\227\204 Frecuencia Grave (Lowpass)\n                  </span>\n                  <span className=\"absolute bottom-2.5 right-3 text-[8.5px] font-mono text-gray-600 pointer-events-none uppercase\">\n                    Frecuencia Aguda \342\226\272\n                  </span>\n                  <span className=\"absolute top-2.5 left-3 text-[8.5px] font-mono text-gray-600 pointer-events-none uppercase\">\n                    \342\226\262 Resonancia M\303\241xima (Filo Q)\n                  </span>\n\n                  {/* Pulsing pointer node */}\n                  <motion.div\n                    className={`absolute -translate-x-1/2 translate-y-1/2 w-6 h-6 rounded-full flex items-center justify-center pointer-events-none ${\n                      selectedTrack.color === \"cyan\" ? \"bg-cyber-cyan/20 border-2 border-cyber-cyan\" : \n                      selectedTrack.color === \"violet\" ? \"bg-cyber-violet/20 border-2 border-cyber-violet\" : \"bg-cyber-green/20 border-2 border-cyber-green\"\n                    }`}\n                    style={{\n                      left: `${xyVal.x * 100}%`,\n                      bottom: `${xyVal.y * 100}%`,\n                    }}\n                    animate={{\n                      scale: isPlaying ? [1, 1.15, 1] : 1\n                    }}\n                    transition={{\n                      repeat: Infinity,\n                      duration: 1.5,\n                      ease: \"easeInOut\"\n                    }}\n                  >\n                    <span className={`w-2.5 h-2.5 rounded-full ${\n                      selectedTrack.color === \"cyan\" ? \"bg-cyber-cyan\" : \n                      selectedTrack.color === \"violet\" ? \"bg-cyber-violet\" : \"bg-cyber-green\"\n                    }`} />\n                  </motion.div>\n                </div>\n              </div>\n\n            </div>\n\n          </div>\n\n        </div>\n\n      </div>\n    </section>\n  );\n}\n"
    }
