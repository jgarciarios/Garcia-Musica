    replacement_chunks {
      replacement_content: "import { motion } from \"motion/react\";\nimport { Play, Calendar, Disc, Volume2, Cpu } from \"lucide-react\";\n\ninterface HeroProps {\n  onCtaclick: (targetId: string) => void;\n}\n\nexport default function Hero({ onCtaclick }: HeroProps) {\n  return (\n    <section className=\"relative min-h-[92vh] flex flex-col justify-center items-center px-4 overflow-hidden pt-20 pb-16\">\n      {/* Mesh Grid Overlay */}\n      <div className=\"absolute inset-0 grid-mesh z-0\" />\n      \n      {/* Background radial glowing effects */}\n      <div className=\"absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-cyber-violet/10 rounded-full blur-[120px] pointer-events-none\" />\n      <div className=\"absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[450px] h-[450px] bg-cyber-green/5 rounded-full blur-[140px] pointer-events-none\" />\n      \n      {/* Studio Header Ribbon */}\n      <motion.div\n        initial={{ opacity: 0, y: -20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ duration: 0.8 }}\n        className=\"z-10 flex items-center gap-3 px-4 py-2 rounded-full border border-white/5 bg-white/[0.02] backdrop-blur-md mb-8 text-xs font-mono text-gray-400 tracking-wider\"\n      >\n        <span className=\"flex h-2 w-2 rounded-full bg-cyber-green animate-pulse\" />\n        ESTUDIOS GARC\303\215A M\303\232SICA <span className=\"text-white/20\">|</span> VANGUARD AUDIO ENGINE v4.1\n      </motion.div>\n\n      {/* Massive Headline */}\n      <div className=\"z-10 text-center max-w-5xl\">\n        <motion.h1\n          initial={{ opacity: 0, filter: \"blur(8px)\" }}\n          animate={{ opacity: 1, filter: \"blur(0px)\" }}\n          transition={{ duration: 1, delay: 0.2 }}\n          className=\"font-display text-5xl md:text-8xl font-bold tracking-tighter text-white leading-none mb-6\"\n        >\n          EL SONIDO DEL <br className=\"hidden md:inline\" />\n          <span className=\"text-transparent bg-clip-text bg-gradient-to-r from-cyber-cyan via-cyber-violet to-cyber-green text-glow-violet\">\n            FUTURO ANAL\303\223GICO\n          </span>\n        </motion.h1>\n\n        <motion.p\n          initial={{ opacity: 0 }}\n          animate={{ opacity: 1 }}\n          transition={{ duration: 0.8, delay: 0.4 }}\n          className=\"text-gray-450 text-base md:text-xl max-w-2xl mx-auto font-sans font-light tracking-wide leading-relaxed mb-12\"\n        >\n          Productora Boutique, Mezcla y M\303\241ster de car\303\241cter h\303\255brido. Esculpiendo pistas con la calidez del hardware valvular real y el impacto del ma\303\261ana digital.\n        </motion.p>\n      </div>\n\n      {/* CTAs */}\n      <motion.div\n        initial={{ opacity: 0, y: 20 }}\n        animate={{ opacity: 1, y: 0 }}\n        transition={{ duration: 0.8, delay: 0.6 }}\n        className=\"z-10 flex flex-col sm:flex-row gap-5 justify-center items-center w-full max-w-md mx-auto\"\n      >\n        <button\n          onClick={() => onCtaclick(\"portfolio\")}\n          className=\"w-full sm:w-auto px-8 py-4 rounded-xl font-display font-medium text-sm tracking-wider uppercase bg-white text-black hover:bg-cyber-cyan transition-all duration-300 transform hover:scale-[1.03] flex items-center justify-center gap-3 cursor-pointer shadow-lg hover:shadow-cyber-cyan/25\"\n        >\n          <Play className=\"w-4 h-4 fill-black\" />\n          Probar Sintetizador\n        </button>\n\n        <button\n          onClick={() => onCtaclick(\"contacto\")}\n          className=\"w-full sm:w-auto px-8 py-4 rounded-xl font-display font-medium text-sm tracking-wider uppercase border border-white/10 bg-white/[0.02] hover:bg-white/[0.06] hover:border-cyber-violet hover:text-cyber-violet transition-all duration-300 hover:shadow-cyber-violet/20 flex items-center justify-center gap-3 cursor-pointer\"\n        >\n          <Calendar className=\"w-4 h-4\" />\n          Agendar Sesi\303\263n\n        </button>\n      </motion.div>\n\n      {/* Audio Gear Status / Rack Dashboard */}\n      <motion.div\n        initial={{ opacity: 0 }}\n        animate={{ opacity: 1 }}\n        transition={{ duration: 1, delay: 0.8 }}\n        className=\"z-10 mt-20 w-full max-w-4xl grid grid-cols-2 md:grid-cols-4 gap-4 px-4 font-mono\"\n      >\n        <div className=\"glass-panel p-4 rounded-xl text-center md:text-left relative overflow-hidden group hover:border-cyber-cyan/30 transition-all duration-300\">\n          <div className=\"absolute top-0 left-0 w-1 h-full bg-cyber-cyan scale-y-0 group-hover:scale-y-100 transition-all duration-300\" />\n          <p className=\"text-[10px] text-gray-500 uppercase tracking-widest flex items-center justify-center md:justify-start gap-1\">\n            <Volume2 className=\"w-3 h-3 text-cyber-cyan\" /> DAC Latency\n          </p>\n          <p className=\"text-xl font-bold text-white mt-1 text-glow-cyan\">0.82 ms</p>\n          <p className=\"text-[9px] text-gray-600 mt-0.5\">Direct ASIC Routing</p>\n        </div>\n\n        <div className=\"glass-panel p-4 rounded-xl text-center md:text-left relative overflow-hidden group hover:border-cyber-violet/30 transition-all duration-300\">\n          <div className=\"absolute top-0 left-0 w-1 h-full bg-cyber-violet scale-y-0 group-hover:scale-y-100 transition-all duration-300\" />\n          <p className=\"text-[10px] text-gray-500 uppercase tracking-widest flex items-center justify-center md:justify-start gap-1\">\n            <Cpu className=\"w-3 h-3 text-cyber-violet\" /> DSP Engine\n          </p>\n          <p className=\"text-xl font-bold text-white mt-1 text-glow-violet\">UAD-3 Octo</p>\n          <p className=\"text-[9px] text-gray-600 mt-0.5\">96kHz - Dual Summing</p>\n        </div>\n\n        <div className=\"glass-panel p-4 rounded-xl text-center md:text-left relative overflow-hidden group hover:border-cyber-green/30 transition-all duration-300\">\n          <div className=\"absolute top-0 left-0 w-1 h-full bg-cyber-green scale-y-0 group-hover:scale-y-100 transition-all duration-300\" />\n          <p className=\"text-[10px] text-gray-500 uppercase tracking-widest flex items-center justify-center md:justify-start gap-1\">\n            <Disc className=\"w-3 h-3 text-cyber-green\" /> Summing Console\n          </p>\n          <p className=\"text-xl font-bold text-white mt-1 text-glow-green\">SSL 4000G</p>\n          <p className=\"text-[9px] text-gray-600 mt-0.5\">Anal\303\263gica Pura</p>\n        </div>\n\n        <div className=\"glass-panel p-4 rounded-xl text-center md:text-left relative overflow-hidden group hover:border-white/10 transition-all duration-300\">\n          <div className=\"absolute top-0 left-0 w-1 h-full bg-white scale-y-0 group-hover:scale-y-100 transition-all duration-300\" />\n          <p className=\"text-[10px] text-gray-500 uppercase tracking-widest flex items-center justify-center md:justify-start gap-1\">\n            \342\232\241 Tube Warmth\n          </p>\n          <p className=\"text-xl font-bold text-white mt-1\">100% Valve</p>\n          <p className=\"text-[9px] text-gray-600 mt-0.5\">Telefunken ECC83</p>\n        </div>\n      </motion.div>\n    </section>\n  );\n}\n"
    }
