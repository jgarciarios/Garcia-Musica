    replacement_chunks {
      replacement_content: "import { useState, useEffect } from \"react\";\nimport { motion, AnimatePresence } from \"motion/react\";\nimport Hero from \"./components/Hero\";\nimport AudioPlayer from \"./components/AudioPlayer\";\nimport Services from \"./components/Services\";\nimport Testimonials from \"./components/Testimonials\";\nimport ContactForm from \"./components/ContactForm\";\nimport { Music, Sliders, MessageSquare, Activity, Headphones, Mail, Instagram, Disc } from \"lucide-react\";\n\nexport default function App() {\n  const [scrolled, setScrolled] = useState(false);\n  const [activeTab, setActiveTab] = useState(\"hero\");\n\n  // Handle header blur during page scroll\n  useEffect(() => {\n    const handleScroll = () => {\n      setScrolled(window.scrollY > 30);\n      \n      // Determine active section for nav indicator\n      const sections = [\"portfolio\", \"servicios\", \"testimonios\", \"contacto\"];\n      let currentSection = \"hero\";\n      \n      for (const section of sections) {\n        const element = document.getElementById(section);\n        if (element) {\n          const rect = element.getBoundingClientRect();\n          if (rect.top <= 160 && rect.bottom >= 160) {\n            currentSection = section;\n            break;\n          }\n        }\n      }\n      setActiveTab(currentSection);\n    };\n\n    window.addEventListener(\"scroll\", handleScroll);\n    return () => window.removeEventListener(\"scroll\", handleScroll);\n  }, []);\n\n  const scrollToSection = (id: string) => {\n    const element = document.getElementById(id);\n    if (element) {\n      element.scrollIntoView({ behavior: \"smooth\" });\n    }\n  };\n\n  return (\n    <div className=\"relative min-h-screen bg-[#020203] text-gray-100 selection:bg-cyber-cyan/30 selection:text-white\">\n      {/* GLOWING AMBIENT CORE BACKGROUNDS */}\n      <div className=\"fixed top-0 inset-0 pointer-events-none z-0 overflow-hidden\">\n        <div className=\"absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-cyber-violet/5 rounded-full blur-[200px]\" />\n        <div className=\"absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-cyber-green/5 rounded-full blur-[200px]\" />\n      </div>\n\n      {/* HEADER HUD / NAVBAR */}\n      <header\n        className={`fixed top-0 left-0 right-0 z-50 transition-all duration-300 ${\n          scrolled\n            ? \"py-3 bg-black/80 backdrop-blur-xl border-b border-white/5 shadow-2xl\"\n            : \"py-6 bg-transparent\"\n        }`}\n      >\n        <div className=\"max-w-7xl mx-auto px-6 flex items-center justify-between\">\n          {/* Logo brand */}\n          <button\n            onClick={() => window.scrollTo({ top: 0, behavior: \"smooth\" })}\n            className=\"flex items-center gap-3 cursor-pointer select-none group\"\n          >\n            <div className=\"relative w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center overflow-hidden transition-all duration-300 group-hover:border-cyber-cyan\">\n              <Disc className=\"w-5.5 h-5.5 text-white transition-all group-hover:rotate-180 duration-1000\" />\n              <span className=\"absolute bottom-0 right-0 w-2 h-2 rounded-full bg-cyber-cyan animate-pulse\" />\n            </div>\n            \n            <div className=\"text-left\">\n              <span className=\"font-display font-bold text-sm tracking-widest text-white block group-hover:text-glow-white transition-colors\">\n                GARC\303\215A M\303\232SICA\n              </span>\n              <span className=\"font-mono text-[8px] text-gray-500 uppercase tracking-widest block\">\n                Vanguard Studio\n              </span>\n            </div>\n          </button>\n\n          {/* Nav links */}\n          <nav className=\"hidden md:flex items-center gap-1.5 bg-white/[0.02] border border-white/5 p-1 rounded-full font-mono text-[10px] uppercase tracking-wider\">\n            {[\n              { id: \"portfolio\", label: \"01. Sintetizador\", icon: Music },\n              { id: \"servicios\", label: \"02. Servicios\", icon: Sliders },\n              { id: \"testimonios\", label: \"03. Opiniones\", icon:headphonesIcon }, // wait, we will use import Headphones or Disc safely\n              { id: \"contacto\", label: \"04. Reservar\", icon: MessageSquare },\n            ].map((tab) => {\n              const isActive = activeTab === tab.id;\n              return (\n                <button\n                  key={tab.id}\n                  onClick={() => scrollToSection(tab.id)}\n                  className={`px-4 py-2 rounded-full transition-all duration-300 cursor-pointer flex items-center gap-1.5 ${\n                    isActive\n                      ? \"bg-white text-black font-semibold shadow-inner\"\n                      : \"text-gray-400 hover:text-white\"\n                  }`}\n                >\n                  <tab.icon className=\"w-3 h-3\" />\n                  {tab.label}\n                </button>\n              );\n            })}\n          </nav>\n\n          {/* Control Room CTA */}\n          <div className=\"flex items-center gap-4\">\n            <button\n              onClick={() => scrollToSection(\"contacto\")}\n              className=\"px-5 py-2.5 rounded-full font-mono text-[10px] uppercase font-bold tracking-widest bg-white/[0.03] border border-white/10 text-white hover:bg-white hover:text-black hover:border-white hover:shadow-lg transition-all duration-300 cursor-pointer\"\n            >\n              Contactar\n            </button>\n          </div>\n        </div>\n      </header>\n\n      {/* CORE SECTIONS */}\n      <main className=\"relative z-10\">\n        <Hero onCtaclick={scrollToSection} />\n        \n        <AudioPlayer />\n        \n        <Services />\n        \n        <Testimonials />\n        \n        <ContactForm />\n      </main>\n\n      {/* FUTURISTIC PREMIUM FOOTER */}\n      <footer className=\"relative bg-black border-t border-white/5 py-16 px-6 font-sans\">\n        <div className=\"max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-12 text-left items-start\">\n          \n          {/* Logo & details */}\n          <div className=\"md:col-span-4 space-y-4\">\n            <div className=\"flex items-center gap-3\">\n              <div className=\"w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center relative\">\n                <Disc className=\"w-5.5 h-5.5 text-white\" />\n              </div>\n              <span className=\"font-display font-medium tracking-widest text-[#f3f4f6] text-sm\">\n                GARC\303\215A M\303\232SICA\n              </span>\n            </div>\n            \n            <p className=\"text-xs text-gray-500 font-light leading-relaxed max-w-sm\">\n              Estudio boutique de producci\303\263n y posproducci\303\263n de vanguardia. Ofrecemos sonido premium de car\303\241cter tridimensional e industrial bajo especificaciones de hardware anal\303\263gico clase A.\n            </p>\n\n            <div className=\"pt-2 font-mono text-[9px] text-gray-600 uppercase space-y-0.5\">\n              <p>COORDENADAS S\303\223NICAS: 40.4168\302\260 N, 3.7038\302\260 W</p>\n              <p>TIME: GMT-5 | LATENCY STATUS: 0.00ms</p>\n            </div>\n          </div>\n\n          {/* Quick links */}\n          <div className=\"md:col-span-4 space-y-4 font-mono text-xs\">\n            <p className=\"text-gray-400 uppercase tracking-widest text-[9px]\">DIRECCION INTEGRAL</p>\n            <ul className=\"space-y-2\">\n              <li>\n                <button onClick={() => scrollToSection(\"portfolio\")} className=\"text-gray-500 hover:text-white transition-colors cursor-pointer text-left\">\n                  \342\206\222 SINTETIZADOR INTERACTIVO\n                </button>\n              </li>\n              <li>\n                <button onClick={() => scrollToSection(\"servicios\")} className=\"text-gray-500 hover:text-white transition-colors cursor-pointer text-left\">\n                  \342\206\222 CAT\303\201LOGO DE SERVICIOS\n                </button>\n              </li>\n              <li>\n                <button onClick={() => scrollToSection(\"testimonios\")} className=\"text-gray-500 hover:text-white transition-colors cursor-pointer text-left\">\n                  \342\206\222 VOCES DEL ESTUDIO\n                </button>\n              </li>\n              <li>\n                <button onClick={() => scrollToSection(\"contacto\")} className=\"text-gray-500 hover:text-white transition-colors cursor-pointer text-left\">\n                  \342\206\222 AGENDAR UNA SESI\303\223N DE COMPILACI\303\223N\n                </button>\n              </li>\n            </ul>\n          </div>\n\n          {/* Social connections */}\n          <div className=\"md:col-span-4 space-y-4\">\n            <p className=\"text-gray-400 font-mono uppercase tracking-widest text-[9px] text-left\">CANALES SOCIO-CREATIVOS</p>\n            \n            <div className=\"flex gap-4\">\n              <a\n                href=\"https://instagram.com\"\n                target=\"_blank\"\n                rel=\"noreferrer\"\n                className=\"w-10 h-10 rounded-xl bg-white/[0.02] border border-white/5 hover:border-cyber-violet hover:bg-cyber-violet/5 hover:text-cyber-violet transition-all duration-300 flex items-center justify-center text-gray-400 cursor-pointer\"\n              >\n                <Instagram className=\"w-5 h-5\" />\n              </a>\n              \n              <a\n                href=\"mailto:juanignaciogarciarios@gmail.com\"\n                className=\"w-10 h-10 rounded-xl bg-white/[0.02] border border-white/5 hover:border-cyber-cyan hover:bg-cyber-cyan/5 hover:text-cyber-cyan transition-all duration-300 flex items-center justify-center text-gray-400 cursor-pointer\"\n              >\n                <Mail className=\"w-5 h-5\" />\n              </a>\n\n              <a\n                href=\"https://spotify.com\"\n                target=\"_blank\"\n                rel=\"noreferrer\"\n                className=\"w-10 h-10 rounded-xl bg-white/[0.02] border border-white/5 hover:border-cyber-green hover:bg-cyber-green/5 hover:text-cyber-green transition-all duration-300 flex items-center justify-center text-gray-400 cursor-pointer\"\n              >\n                <Headphones className=\"w-5 h-5\" />\n              </a>\n            </div>\n\n            <p className=\"text-[10px] font-mono text-gray-500 text-left pt-2 leading-tight\">\n              Dise\303\261o Ultra-Premium listo para producci\303\263n. \302\251 {new Date().getFullYear()} Garc\303\255a M\303\272sica. Todos los derechos reservados.\n            </p>\n          </div>\n\n        </div>\n      </footer>\n    </div>\n  );\n}\n\n// Quick inner constant helper for headphones mapping\nconst headphonesIcon = Headphones;\n"
    }
